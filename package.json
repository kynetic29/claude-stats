{
  "name": "claude-stats",
  "version": "0.2.2",
  "description": "Real-time Claude Code usage dashboard for dedicated monitors",
  "author": "kynetic29",
  "main": "electron/main.js",
  "scripts": {
    "dev:vite": "vite build --watch",
    "dev:electron": "wait-on dist/src/dashboard/index.html && electron .",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "build": "vite build",
    "package": "vite build && electron-builder",
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.0.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.5",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.claudestats.app",
    "productName": "ClaudeStats",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "forceCodeSigning": false,
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
